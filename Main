// --- User Visible Inputs Only ---
input double   RiskPercent          = 2.0;          // Risk per trade (% of equity)
enum EALanguage { English, French };
input EALanguage SelectedLanguage = English;          // Language for labels

// --- Hidden Inputs (User doesn't need to see these) ---
input double   LotSizeFixed         = 0.0;          // Fixed lot size (0 = use risk)
input ENUM_TIMEFRAMES TF             = PERIOD_CURRENT;
input int      MagicNumber           = 123456;
input int      MaxRetries            = 3;
input double   FreezeDistancePoints  = 5.0;

input bool     UseATRFilter        = true;
input int      ATRShortPeriod      = 14;
input int      ATROutPeriod        = 50;
input int      ATRHistorySize      = 200;
input double   ATRSensitivity      = 1.0;
input double   ATRLearningAlpha    = 0.1;
input int      MinTradesToLearn    = 10;
input double   LearningSmoothing   = 0.3;

input int      MaxConsecutiveLosses   = 5;
input double   BaseTradeSizeMultiplier = 1.0;
input double   MinTradeSizeMultiplier  = 0.5;
input double   StreakScorePenalty      = 0.5;
input double   TargetRR                = 2.0;

input bool     UseADXRegimeFilter = true;
input int      ADXPeriod          = 14;
input double   ADXTrendThreshold  = 25.0;
input double   ADXRangingThreshold = 20.0;
input double   RangingSizeReduction = 0.5;
input double   WeakTrendSizeReduction = 0.75;
input double   RangingScorePenalty = 0.3;
input double   WeakTrendScorePenalty = 0.1;

input int      LearningHistorySize = 100;
input double   LearningSmoothingThreshold = 0.3;
input bool     UseVirtualWins      = true;
input int      VirtualWinsRequired = 1;

// --- Include modules ---
#include <Trade/Trade.mqh>
#include <ConsecutiveLossManager.mqh>
#include <SelfLearning.mqh>
